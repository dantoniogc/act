        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 2. Carga del archivo CSV\n",
        "url = \"https://raw.githubusercontent.com/mwaskom/seaborn-data/master/diamonds.csv\"\n",
        "df = pd.read_csv(url)\n",
        "\n",
        "# 3. Mostrar las últimas 5 filas y resumen estadístico\n",
        "print(\"--- Últimas 5 filas ---\")\n",
        "print(df.tail())\n",
        "\n",
        "print(\"\\n--- Resumen Estadístico ---\")\n",
        "print(df.describe())\n",
        "\n",
        "# 4. Eliminar filas con dimensiones x, y, o z iguales a 0\n",
        "# Filtramos manteniendo solo aquellas filas donde x, y, z son mayores a 0\n",
        "df = df[(df['x'] > 0) & (df['y'] > 0) & (df['z'] > 0)]\n",
        "\n",
        "# 5. Crear columna volumen_aprox (x * y * z)\n",
        "df['volumen_aprox'] = df['x'] * df['y'] * df['z']\n",
        "\n",
        "print(\"\\nLimpieza completada. Filas restantes:\", len(df))"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 1. Gráfico de Caja (Boxplot) para el precio\n",
        "plt.figure(figsize=(8, 6))\n",
        "plt.boxplot(df['price'])\n",
        "plt.title('Distribución de Precios de Diamantes (Boxplot)')\n",
        "plt.ylabel('Precio (USD)')\n",
        "plt.xlabel('Diamantes')\n",
        "plt.show()\n",
        "\n",
        "# 2. Gráfico de Dispersión (Scatter): volumen_aprox vs price\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.scatter(df['volumen_aprox'], df['price'], alpha=0.5, color='teal')\n",
        "plt.title('Relación entre Volumen Aproximado y Precio')\n",
        "plt.xlabel('Volumen Aproximado (x * y * z)')\n",
        "plt.ylabel('Precio (USD)')\n",
        "plt.grid(True, linestyle='--', alpha=0.7)\n",
        "plt.show()\n",
        "\n",
        "# 3. Gráfico de Barras: Cantidad de piezas por tipo de corte (cut)\n",
        "# Primero contamos las ocurrencias\n",
        "conteo_cortes = df['cut'].value_counts()\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "conteo_cortes.plot(kind='bar', color='skyblue', edgecolor='black')\n",
        "plt.title('Cantidad de Diamantes por Tipo de Corte')\n",
        "plt.xlabel('Tipo de Corte')\n",
        "plt.ylabel('Cantidad de Piezas')\n",
        "plt.xticks(rotation=45)\n",
        "plt.show()"
